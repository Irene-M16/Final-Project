doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Nyondo Sales Dashboard
  link(rel='stylesheet' href='style.css')
  // Using Google Fonts for that clean sans-serif look
  link(href='https://googleapis.com' rel='stylesheet')
  link(rel='stylesheet' href='../css/salesDash.css')
.dashboard-container
  // Sidebar
  aside.sidebar
    .logo-section
      .logo-icon &#x1F3E2;
      div
        h1.brand-name NYONDO
        p.brand-sub Sales Portal
    nav.nav-menu
      a.nav-item.active(href='sales-dash.html')
        span.icon &#x1F4CA;
        |  Dashboard
      a.nav-item(href='record.html')
        span.icon &#x1F6D2;
        |  Record Sale
      a.nav-item(href='stockLevel.html')
        span.icon &#x1F4E6;
        |  Check Stock
      a.nav-item(href='receipts.html')
        span.icon &#x1F4D1;
        |  Receipts
    .sidebar-footer
      a.nav-item(href='../html/index.html')
        span.icon &rarrhk;&#xFE0F;
        |  Logout
  // Main Content
  main.main-content
    // Header
    header.header
      .header-left
        h2 Dashboard
        p.date-text Monday, April 20, 2026
      .header-right
        .notification-bell &#x1F514;
        .user-profile
          .user-info
            span.user-name User&apos; name
            span.user-role Sales Attendant
          .user-avatar &#x1F464;
    // Top KPI Cards
    section.kpi-grid
      .card.kpi-card
        .card-header
          span.card-icon.pink-bg $
          span.badge.positive +12.5%
        p.card-label Today&apos;s Sales
        h3.card-value 3,160,000 UGX
      .card.kpi-card
        .card-header
          span.card-icon.pink-bg &#x1F4C8;
          span.badge.positive +8
        p.card-label Transactions
        h3.card-value 24
      .card.kpi-card
        .card-header
          span.card-icon.pink-bg &#x1F4CB;
          span.badge.active-badge Active
        p.card-label Items Sold
        h3.card-value 186
    // Action Buttons
    section.action-grid
      a.action-btn.primary-btn(href='record.html')
        span.btn-icon +
        |  Record Sale
      a.action-btn(href='stockLevel.html')
        span.btn-icon &#x1F4E6;
        |  Check Stock
      a.action-btn(href='receipts.html')
        span.btn-icon &#x1F4D1;
        |  View Receipts
      a.action-btn(href='search-orders.html')
        span.btn-icon &#x1F50D;
        |  Search Orders
    // Recent Sales Table
    section.table-section
      h3.section-title Recent Sales
      .table-container
        table
          thead
            tr
              th Invoice ID
              th Customer
              th Items
              th Amount (UGX)
              th Transport
              th Time
              th Status
          tbody
            tr
              td INV-2026-0845
              td Mukasa Construction Ltd
              td.items-cell Cement x20, Iron Bars 12mm x15
              td 1,120,000
              td.free-text Free
              td 10:45 AM
              td
                span.status-pill Completed
            tr
              td INV-2026-0844
              td Nakato Builders
              td.items-cell Iron Sheets x25
              td 950,000
              td.free-text Free
              td 10:12 AM
              td
                span.status-pill Completed
            tr
              td INV-2026-0843
              td Wasswa Hardware Supplies
              td.items-cell Wire Mesh x8, Barbed Wire x5
              td 730,000
              td.free-text Free
              td 09:38 AM
              td
                span.status-pill Completed
            tr
              td INV-2026-0842
              td Nambi Projects
              td.items-cell Cement x8, Nails x10
              td 360,000
              td 30,000
              td 09:05 AM
              td
                span.status-pill Completed
