doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Home Page
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css' rel='stylesheet' integrity='sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC' crossorigin='anonymous')
  link(rel='stylesheet' href='../css/index.css')
// navigation
nav.navbar
  .container.nav-content
    .logo
      .logo-box
        img.logo-box(src='../images/logo.png' alt='logo')
      span.logo-text NYONDO General Hardware LTD
    a(href='login.html' style='text-decoration: none')
      button.btn.btn-primary Login to System
// hero section
header.hero
  .container
    .badge
      span.dot
      |  Professional Hardware Management
    h1 Hardware Management System
    p.hero-sub
      | Smart stock, sales, and financial management made simple. Streamline
      | your wholesale and retail operations with our comprehensive business
      | management platform.
    .hero-btns
      a(href='signup.html' style='text-decoration: none')
        button.btn.btn-primary.btn-large Get Started
      button.btn.btn-secondary.btn-large Learn More
    .stats-grid
      .stat-item
        span.stat-number 500+
        span.stat-label Products Managed
      .stat-item
        span.stat-number 24/7
        span.stat-label System Access
      .stat-item
        span.stat-number 100%
        span.stat-label Secure
// features section
section.features
  .container
    .features-grid
      .feature-card
        .icon-box &#x1F4E6;
        h3 Stock Management
        p
          | Track inventory levels, add new stock, and manage pricing in
          | real-time
      .feature-card
        .icon-box &#x1F527;
        h3 Sales Processing
        p Quick checkout, receipt generation, and transport calculation
      .feature-card
        .icon-box &#x1F69A;
        h3 Transport Rules
        p
          | Automated transport charges based on purchase amount and distance
      .feature-card
        .icon-box &#x1F3DB;&#xFE0F;
        h3 Deposit Scheme
        p
          | Manage customer deposits for cement, iron bars, and iron sheets
// bootstrap
#carouselExampleDark.carousel.carousel-dark.slide(data-bs-ride='carousel')
  .carousel-indicators
    button.active(type='button' data-bs-target='#carouselExampleDark' data-bs-slide-to='0' aria-current='true' aria-label='Slide 1')
    button(type='button' data-bs-target='#carouselExampleDark' data-bs-slide-to='1' aria-label='Slide 2')
    button(type='button' data-bs-target='#carouselExampleDark' data-bs-slide-to='2' aria-label='Slide 3')
  .carousel-inner
    .carousel-item.active(data-bs-interval='10000')
      img.d-block.w-100(src='../images/computer2.png' alt='comp&phone')
      .carousel-caption.d-none.d-md-block
        h5 First slide label
        p Some representative placeholder content for the first slide.
    .carousel-item(data-bs-interval='2000')
      img.d-block.w-100(src='../images/woman2.png' alt='woman')
      .carousel-caption.d-none.d-md-block
        h5 Second slide label
        p Some representative placeholder content for the second slide.
    .carousel-item
      img.d-block.w-100(src='../images/items.png' alt='...')
      .carousel-caption.d-none.d-md-block
        h5 Third slide label
        p Some representative placeholder content for the third slide.
  button.carousel-control-prev(type='button' data-bs-target='#carouselExampleDark' data-bs-slide='prev')
    span.carousel-control-prev-icon(aria-hidden='true')
    span.visually-hidden Previous
  button.carousel-control-next(type='button' data-bs-target='#carouselExampleDark' data-bs-slide='next')
    span.carousel-control-next-icon(aria-hidden='true')
    span.visually-hidden Next
// upto here
// roles section
section.roles
  .container
    .section-header
      h2 Built for Construction Material Specialists
      p
        | Comprehensive management tools for cement, iron bars, nails, wire
        | mesh, barbed wire, and iron sheets
    .roles-grid
      .role-card
        h3 For Sales Teams
        p
          | Quick sales processing, stock checking, receipt generation, and
          | automatic transport calculation
        ul.role-list
          li Record sales transactions
          li Real-time stock availability
          li Auto transport charges
      .role-card
        h3 For Store Managers
        p
          | Complete inventory control, stock registration, pricing
          | management, and low stock alerts
        ul.role-list
          li Add and update inventory
          li Set pricing rules
          li Stock level monitoring
      .role-card
        h3 For Administrators
        p
          | Financial tracking, supplier credit management, deposit scheme
          | oversight, and comprehensive reporting
        ul.role-list
          li User management
          li Supplier credit tracking
          li Deposit scheme management
// Footer
footer.footer
  .container.footer-content
    .logo
      .logo-box &#x1F3E2;
      span.logo-text NYONDO General Hardware LTD
    .copyright
      | &copy; 2026 NYONDO General Hardware LTD. All rights reserved.
