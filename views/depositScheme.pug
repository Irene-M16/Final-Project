doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Deposit Scheme
  link(href='https://googleapis.com' rel='stylesheet')
  link(rel='stylesheet' href='../css/depositScheme.css')
.page-wrapper
  // Sidebar: Natural Scroll Layout
  aside.sidebar
    .sidebar-top
      .logo-section
        .logo-icon &#x1F3E2;
        div
          h1.brand-name NYONDO
          p.brand-sub Admin Portal
      nav.nav-menu
        a.nav-item(href='adminDash')
          span.icon &#x1F4CA;
          |  Dashboard
        a.nav-item(href='userReg')
          span.icon &#x1F465;
          |  Users
        a.nav-item(href='supplier')
          span.icon &#x1F4B3;
          |  Supplier Credit
        a.nav-item.active(href='depositScheme')
          span.icon &#x1F4D1;
          |  Deposit Scheme
        a.nav-item(href='transport')
          span.icon &#x1F69B;
          |  Transport Charges
        a.nav-item(href='reports')
          span.icon &#x1F4CB;
          |  Reports
    .sidebar-bottom
      a.nav-item.logout-link(href='login.html')
        span.icon &rarrhk;&#xFE0F;
        |  Logout
  // Main Content
  main.main-content
    // Organized Header
    header.header
      .header-left
        h2 Deposit Scheme Management
        p.date-text Friday, May 1, 2026
      .header-right
        .bell-box
          span.icon-bell &#x1F514;
          span.red-dot
        .header-divider
        .user-profile
          .user-text
            span.user-name David Musoke
            span.user-role Administrator
          .user-avatar-circle &#x1F464;
    // Search and Action Row
    section.table-controls
      .search-box
        span.search-icon &#x1F50D;
        input(type='text' placeholder='Search by name or NIN...')
      a.primary-btn(href='formDeposit.html') + Register Customer
    // Guidelines Info Box
    .guidelines-box
      span.info-circle &#x24D8;
      .guidelines-text
        strong Deposit Scheme Guidelines
        p
          | Customers register with full name (as per National ID), NIN, and
          | phone number. Eligible products: Cement, Iron Sheets, Iron Bars.
          | Issue temporary receipts for all deposits.
    // Deposits Table (Optimized for no scroll)
    section.table-card
      table.no-scroll-table
        thead
          tr
            th Customer Name
            th NIN
            th Phone Number
            th Total Deposits
            th Product
            th Registered Date
            th Last Deposit
            th Status
            th Action
        tbody
          tr
            td
